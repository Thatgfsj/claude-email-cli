# Email AI Assistant 环境变量配置示例
# 复制为 .env 并填写实际值

# ========== 必需配置 ==========
# 邮箱地址
EMAIL_USER=your@email.com
# 邮箱密码或授权码
EMAIL_PWD=your_auth_code
# IMAP 服务器
IMAP_HOST=imap.qq.com
# SMTP 服务器
SMTP_HOST=smtp.qq.com

# ========== 可选配置 ==========
# 端口（默认）
IMAP_PORT=993
SMTP_PORT=465
# 轮询间隔（秒，默认30）
POLL_INTERVAL=30
# Claude 超时（秒，默认300）
CLAUDE_TIMEOUT=300
# 最大重试次数
MAX_RETRIES=3
# Claude 路径
CLAUDE_PATH=claude

# ========== 安全配置 ==========
# 发件人白名单（多个用逗号分隔）
ALLOWED_SENDERS=your@email.com,friend@qq.com
